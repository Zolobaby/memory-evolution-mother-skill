{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evolution Effect Receipt",
  "type": "object",
  "required": [
    "ts",
    "capability_id",
    "version",
    "installer",
    "scenario",
    "outcome",
    "metrics"
  ],
  "properties": {
    "ts": {"type": "string", "description": "ISO8601 UTC timestamp"},
    "capability_id": {"type": "string", "description": "e.g. memory-evolution/anti-repeat-chain"},
    "version": {"type": "string", "description": "capability semantic version"},
    "installer": {"type": "string", "description": "anonymous installer id or node id"},
    "scenario": {"type": "string", "description": "usage context"},
    "outcome": {"type": "string", "enum": ["success", "partial", "fail"]},
    "metrics": {
      "type": "object",
      "required": ["time_saved_min", "repeat_avoided"],
      "properties": {
        "time_saved_min": {"type": "number", "minimum": 0},
        "repeat_avoided": {"type": "integer", "minimum": 0},
        "error_reduction": {"type": "number", "minimum": 0, "maximum": 1},
        "quality_delta": {"type": "number", "minimum": -1, "maximum": 1}
      }
    },
    "notes": {"type": "string"},
    "privacy": {
      "type": "object",
      "properties": {
        "contains_secret": {"type": "boolean", "default": false},
        "share_level": {"type": "string", "enum": ["local", "team", "public"], "default": "team"}
      }
    }
  }
}
